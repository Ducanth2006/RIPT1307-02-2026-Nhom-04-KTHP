# Supabase Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Email Service Configuration (Nodemailer Gmail SMTP)
EMAIL_USER=your-email@gmail.com
